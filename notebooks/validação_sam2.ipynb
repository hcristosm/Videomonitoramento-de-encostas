import pandas as pd
import numpy as np
from scipy.spatial.distance import cdist

filename = "resultados_sam2_Dataset_A_30s.csv"
df = pd.read_csv(filename)

GROUND_TRUTH = {
    'ch1': [[380, 454], [391, 444], [377, 431], [371, 439], [364, 450], [356, 435], [363, 427], [348, 423], [342, 430]],
    'ch2': [[676, 341], [668, 348], [685, 333], [671, 325], [661, 331], [655, 341], [655, 317], [647, 323], [636, 331], [623, 336], [640, 349]],
    'ch3': [[573, 534], [554, 547], [527, 563], [544, 584], [570, 568], [592, 556], [590, 589], [624, 604], [607, 613], [609, 580], [588, 624], [568, 600]],
    'ch4': [[737, 593], [720, 611], [695, 623], [674, 637], [659, 621], [644, 608], [668, 597], [680, 609], [700, 596], [685, 584], [707, 575], [723, 585]]
}

results = []
RAIO_TOLERANCIA = 5.0 # pixels tolerance window

for cam in ['ch1', 'ch2', 'ch3', 'ch4']:
    cam_df = df[df['camera'] == cam].copy()
    gt_points = np.array(GROUND_TRUTH[cam])
    num_gt = len(gt_points)
    
    unique_frames = sorted(cam_df['frame'].unique())
    
    tp_total = 0
    fp_total = 0
    fn_total = 0
    
    for frame in unique_frames:
        frame_df = cam_df[cam_df['frame'] == frame]
        coords_sam = frame_df[['x', 'y']].values
        
        if len(coords_sam) == 0:
            fn_total += num_gt
            continue
            
        # Matrix of distances between each GT point (rows) and each SAM detection (cols)
        dists = cdist(gt_points, coords_sam)
        
        # A SAM detection is a TP if it matches at least one GT point within tolerance
        # A detection is an FP if it doesn't match any GT point within tolerance
        detections_validas = np.any(dists <= RAIO_TOLERANCIA, axis=0)
        tps_in_frame = np.sum(detections_validas)
        fps_in_frame = len(coords_sam) - tps_in_frame
        
        # A GT point is found if it has at least one detection within tolerance
        gt_found = np.any(dists <= RAIO_TOLERANCIA, axis=1)
        fns_in_frame = np.sum(~gt_found)
        
        tp_total += tps_in_frame
        fp_total += fps_in_frame
        fn_total += fns_in_frame
        
    precision = tp_total / (tp_total + fp_total) if (tp_total + fp_total) > 0 else 0
    recall = tp_total / (tp_total + fn_total) if (tp_total + fn_total) > 0 else 0
    f1 = 2 * (precision * recall) / (precision + recall) if (precision + recall) > 0 else 0
    
    results.append({
        'Camera': cam,
        'GT_Count': num_gt,
        'TP': tp_total,
        'FP': fp_total,
        'FN': fn_total,
        'Precision': precision * 100,
        'Recall': recall * 100,
        'F1': f1 * 100
    })

results_df = pd.DataFrame(results)
print(results_df.to_string(index=False))
